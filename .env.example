# ============================================================
#  Konfigurasi Pearl (PRL) Miner  --  salin ke ".env" lalu edit
#  cp .env.example .env
# ============================================================

# --- Kredensial RPC (dipakai bersama oleh pearld, oyster, prlctl) ---
# Ganti dengan nilai acak yang kuat. JANGAN pakai default di server publik.
RPC_USER=rpcuser
RPC_PASS=ubah-ini-jadi-password-kuat

# --- Alamat mining (taproot, diawali "prl1...") ---
# Dibuat otomatis oleh:  ./pearl-mine.sh wallet
# Setelah dibuat, tempel di sini agar node & miner memakainya.
MINING_ADDRESS=

# --- Jaringan: mainnet | testnet | simnet ---
NETWORK=mainnet

# --- Versi node yang dipasang (kosongkan = auto-deteksi vX.Y.Z terbaru) ---
# Isi manual kalau auto-deteksi gagal, contoh: PEARL_VERSION=v1.1.6
PEARL_VERSION=

# --- Endpoint (default lokal, jangan diubah kecuali paham) ---
PEARLD_RPC_HOST=127.0.0.1
PEARLD_RPC_PORT=44107
WALLET_RPC_PORT=44207

# --- vLLM miner ---
# Model resmi Pearl. Butuh ~140GB VRAM (H200 141GB disarankan / 2xH100).
MODEL=pearl-ai/Llama-3.3-70B-Instruct-pearl
# Token HuggingFace (buat gratis di https://huggingface.co/settings/tokens)
HF_TOKEN=
# Berapa GPU yang dipakai paralel (tensor/data parallel). 1 untuk 1x H200.
TENSOR_PARALLEL=1
GPU_MEMORY_UTILIZATION=0.90
MAX_MODEL_LEN=8192

# --- Path ---
# Lokasi binary pearl setelah install (biasanya ~/.local/bin)
PEARL_BIN_DIR=$HOME/.local/bin
# Folder log
LOG_DIR=$HOME/.pearl-miner/logs
